{
  "info": {
    "name": "Project Management API",
    "_postman_id": "pm-api-collection-v1",
    "description": "Complete API collection for the Project Management API. \n\n## Setup\n1. Set `baseUrl` variable to your API URL (default: http://localhost:5000)\n2. Run **Auth / Login** first — the token is auto-saved to `authToken`\n3. All secured endpoints use `{{authToken}}` automatically\n\n## Seed Credentials\n- Admin: admin@projectmgmt.com / Admin@123\n- PM: pm@projectmgmt.com / Manager@123\n- Dev: dev@projectmgmt.com / Dev@123",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000", "type": "string" },
    { "key": "authToken", "value": "", "type": "string" },
    { "key": "refreshToken", "value": "", "type": "string" },
    { "key": "projectId", "value": "", "type": "string" },
    { "key": "taskId", "value": "", "type": "string" },
    { "key": "epicId", "value": "", "type": "string" },
    { "key": "sprintId", "value": "", "type": "string" },
    { "key": "userId", "value": "", "type": "string" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{authToken}}", "type": "string" }]
  },
  "item": [
    {
      "name": "🔐 Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/v1/auth/register", "host": ["{{baseUrl}}"], "path": ["api","v1","auth","register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\",\n  \"email\": \"john.doe@example.com\",\n  \"password\": \"Password@123\",\n  \"role\": \"Developer\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const res = pm.response.json();",
                  "  pm.collectionVariables.set('authToken', res.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', res.refreshToken);",
                  "  console.log('Token saved:', res.accessToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/v1/auth/login", "host": ["{{baseUrl}}"], "path": ["api","v1","auth","login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@projectmgmt.com\",\n  \"password\": \"Admin@123\"\n}"
            }
          }
        },
        {
          "name": "Login as ProjectManager",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const res = pm.response.json();",
                  "  pm.collectionVariables.set('authToken', res.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', res.refreshToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/v1/auth/login", "host": ["{{baseUrl}}"], "path": ["api","v1","auth","login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"pm@projectmgmt.com\",\n  \"password\": \"Manager@123\"\n}"
            }
          }
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const res = pm.response.json();",
                  "  pm.collectionVariables.set('authToken', res.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', res.refreshToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/v1/auth/refresh-token", "host": ["{{baseUrl}}"], "path": ["api","v1","auth","refresh-token"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"accessToken\": \"{{authToken}}\",\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            }
          }
        }
      ]
